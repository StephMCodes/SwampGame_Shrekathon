  m_Script: {fileID: 11500000, guid: f62944efa3fb7964c8483b1e2182d3e1, type: 3}
  m_Name: GotYouTooHuh
  m_EditorClassIdentifier: Assembly-CSharp::DialogueObject
  dialogue:
  - Rumplestiltskin got you too huh... Never sign a contract with him. Wish someone
    told me. Now im stuck here.
  - Guess you can give up and set up shop here like us. There's no escape.
  - Word around here is that a pumpkin carriage can get you out of this place. Never
    seen it done before. Its just a fairy tale!
  - See you around...
  responses: []
